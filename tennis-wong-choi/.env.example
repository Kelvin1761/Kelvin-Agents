DATABASE_URL=sqlite:///tennis_wc.db

TENNIS_PROVIDER=mock
TENNIS_API_KEY=
TENNIS_API_BASE_URL=https://tennis.bzzoiro.com/api

ODDS_PROVIDER=mock
ODDS_API_KEY=
ODDS_API_BASE_URL=
SPORTSBET_API_KEY=
SPORTSBET_API_BASE_URL=https://wagerwise-odds.com
SPORTSBET_BOOKMAKER_NAME=Sportsbet
SPORTSBET_SOURCE_MODE=api
SPORTSBET_ALLOWED_SCRAPE_FALLBACK=false

NEWS_PROVIDER=mock
NEWS_API_KEY=
NEWS_API_BASE_URL=

OPENAI_API_KEY=

DATA_MAX_STALENESS_MINUTES_ODDS=10
DATA_MAX_STALENESS_HOURS_PLAYER_STATS=24
DATA_MAX_STALENESS_HOURS_RANKINGS=168
DATA_MAX_STALENESS_HOURS_TOURNAMENT_METADATA=720

AI_REVIEW_ENABLED=true

MIN_EDGE_MATCH_WINNER=0.035
MIN_EDGE_HANDICAP=0.05
MIN_EDGE_TOTALS=0.05

# Tenth-Kelly staking, sized on model prob vs actual odds. Bets floored at
# MIN_STAKE_UNITS (start at 1u) and capped at MAX_STAKE_UNITS. 1u ~= 1% of the bankroll.
MAX_STAKE_UNITS=5.0
MIN_STAKE_UNITS=1.0
KELLY_FRACTION=0.10
STAKE_ROUND_INCREMENT=0.5
DEFAULT_BANKROLL_UNITS=100
