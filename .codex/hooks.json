{
  "SessionStart": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "node \".codex/hooks/gsd-check-update.js\""
        }
      ]
    }
  ],
  "SubagentStart": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "node \".codex/hooks/gsd-context-monitor.js\"",
          "timeout": 10
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "node \".codex/hooks/gsd-context-monitor.js\"",
          "timeout": 10
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "node \".codex/hooks/gsd-context-monitor.js\"",
          "timeout": 10
        }
      ]
    }
  ]
}